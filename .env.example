# Copy to .env and fill in. .env is gitignored — never commit real credentials.
#
# QRP is a DB-per-package platform on ONE Postgres instance: sym is a peer package (a common
# read-only upstream, not a hub); each module owns its own database (sym · macro · signal ·
# backtest · optimiser · altdata · qrp [jobs] · portfolios).
# Credentials are INSTANCE-LEVEL (shared by every package) → libpq-standard PG* names, not a
# per-package or sym-specific prefix. Each package only names its own database (dbname = package).

# Shared Postgres instance credentials (libpq standard) — the PRIVILEGED path (writes +
# op-execution). Consumer READS of sym use the read-only role below.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
# PGPASSWORD=
# (PGDATABASE deliberately left unset — each package sets its own dbname.)

# Least-privilege read-only role for consumer reads of the sym package (Story QH.3).
# Provision it with `uv run python tools/provision_readonly.py` (or it rides deploy_all);
# the role gets SELECT on the AR-R3 read surface only — a write to sym is physically
# refused. Set BOTH below to opt in; until PGRO_USER is set, sym reads fall back to full
# creds (read-only by convention). PGRO_PASSWORD is also what the provisioner sets ON the
# role. (Set PGRO_USER without PGRO_PASSWORD and reads attempt a passwordless DSN that
# fails — set both, or neither.)
# PGRO_USER=qrp_readonly
# PGRO_PASSWORD=
# SYM_READONLY_URL=postgresql://qrp_readonly:pw@host:5432/sym   # whole-DSN override (wins)

# Per-package overrides (optional) — move a package to its own host/db:
# MACRO_DATABASE_URL=postgresql://user:pw@host:5432/macro
# SYM_DATABASE_URL=postgresql://user:pw@host:5432/sym

# sym CODE checkout for Operate jobs (a path, not a credential):
# SYM_PROJECT_DIR=C:/Projects/sym

# Where the console's server-side fetches reach the API (default below):
# API_BASE=http://127.0.0.1:8000

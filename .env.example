# Copy to .env and fill in. .env is gitignored — never commit real credentials.
#
# QRP is a DB-per-package platform on ONE Postgres instance: sym is the hub; each module owns
# its own database (sym · macro · signal · backtest · optimiser · altdata · qrp [Operate jobs] ·
# portfolios). package_dsn() resolves each on this instance using SYM_DB_* below, with
# dbname = the package name. Override a package via <PKG>_DATABASE_URL or <PKG>_DB_* (e.g.
# PORTFOLIOS_DB_HOST=...) to move it to its own host.

# Base credentials + the sym hub database:
SYM_DB_HOST=localhost
SYM_DB_PORT=5432
SYM_DB_NAME=sym
SYM_DB_USER=postgres
# SYM_DB_PASSWORD=

# Optional single-DSN override for the hub (wins if present):
# SYM_DATABASE_URL=postgresql://postgres:password@localhost:5432/sym

# Where the console's server-side fetches reach the API (default below):
# API_BASE=http://127.0.0.1:8000

{
  "name": "qrp",
  "version": "0.0.0",
  "private": true,
  "description": "QRP (Quant Research Platform) monorepo — console + API over the sym warehouse.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm --workspace web run dev",
    "dev:api": "uv run uvicorn qrp_api.main:app --port 8001 --host 127.0.0.1",
    "build:web": "npm --workspace web run build"
  }
}
